  METHOD mem_ld_i32.
    DATA lv_b TYPE x LENGTH 4.
    lv_b = mv_mem+iv_addr(4).
    " Little-endian to big-endian
    DATA(lv_r) = lv_b+3(1) && lv_b+2(1) && lv_b+1(1) && lv_b+0(1).
    rv = lv_r.
  ENDMETHOD.
  METHOD mem_st_i32.
    DATA lv_b TYPE x LENGTH 4.
    lv_b = iv_val.
    " Big-endian to little-endian
    DATA(lv_r) = lv_b+3(1) && lv_b+2(1) && lv_b+1(1) && lv_b+0(1).
    mv_mem+iv_addr(4) = lv_r.
  ENDMETHOD.
  METHOD mem_ld_i32_8u.
    DATA lv_b TYPE x LENGTH 1.
    lv_b = mv_mem+iv_addr(1).
    rv = lv_b.
  ENDMETHOD.
  METHOD mem_ld_i32_8s.
    DATA lv_b TYPE x LENGTH 1.
    lv_b = mv_mem+iv_addr(1).
    rv = lv_b.
    IF rv > 127. rv = rv - 256. ENDIF.
  ENDMETHOD.
  METHOD mem_ld_i32_16u.
    DATA lv_b TYPE x LENGTH 2.
    lv_b = mv_mem+iv_addr(2).
    DATA(lv_r) = lv_b+1(1) && lv_b+0(1).
    rv = lv_r.
  ENDMETHOD.
  METHOD mem_st_i32_8.
    DATA lv_b TYPE x LENGTH 1.
    lv_b = iv_val.
    mv_mem+iv_addr(1) = lv_b.
  ENDMETHOD.
  METHOD mem_st_i32_16.
    DATA lv_b TYPE x LENGTH 2.
    lv_b = iv_val.
    DATA(lv_r) = lv_b+1(1) && lv_b+0(1).
    mv_mem+iv_addr(2) = lv_r.
  ENDMETHOD.
  METHOD mem_grow.
    rv = mv_mem_pages.
    DATA(lv_new_bytes) = iv_pages * 65536.
    DATA lv_zeros TYPE xstring.
    DO lv_new_bytes TIMES.
      CONCATENATE lv_zeros '00' INTO lv_zeros IN BYTE MODE.
    ENDDO.
    CONCATENATE mv_mem lv_zeros INTO mv_mem IN BYTE MODE.
    mv_mem_pages = mv_mem_pages + iv_pages.
  ENDMETHOD.
  METHOD __main_void.
    rv = mo_c02->__main_void( ).
  ENDMETHOD.
